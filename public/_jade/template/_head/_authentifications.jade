-let authentifications = WEBSITE.authentifications;
if authentifications.googleSiteVerificationId
    meta(name="google-site-verification" content=Website.decodeAuthentification(
        authentifications.googleSiteVerificationId))
if authentifications.bingWebmasterValidationId
    meta(name="msvalidate.01" content=Website.decodeAuthentification(
        authentifications.bingWebmasterValidationId))
if authentifications.facebookApplicationId
    meta(property='fb:app_id' content=Website.decodeAuthentification(
        authentifications.facebookApplicationId))
if authentifications.yandexWebmasterVerificationCode
    meta(name="yandex-verification" content=Website.decodeAuthentification(
        authentifications.yandexWebmasterVerificationCode))