include _difficulty

-
    /**
    * A module type hold the active count of modules in a document.
    */
    class DocumentModuleType {
        /**
        * Constructs a well-defined module type.
        * @param {String} name the name of the module type.
        * @param {Number} count the active count of modules of the type.
        * @throws {Error} if the given module type name is undefined. 
        */
        constructor(name, count = 0) {
            if (!name) {
                throw new Error('Undefined module type name.');
            }
            this.name = name;
            this.count = count;
        }

        /**
        * Fetches a defined module type of a given name.
        * @param {String} name the name of the module to fetch.
        * @returns {Type} the module type of the given name.
        * @throws {Error} if there is no module type of the given name.
        * @see DocumentModuleType.TYPES the defined module types.
        */
        static of(name) {
            for (const TYPE of DocumentModuleType.TYPES) {
                if (TYPE.name === name) {
                    return TYPE;
                }
            }
            throw new Error('No defined module type of the name ' + name + '.');
        }
    }

    /**
    * The enumeration of module types.
    */
    DocumentModuleType.TYPES = [
        new DocumentModuleType('definition'),
        new DocumentModuleType('example'),
        new DocumentModuleType('exercise'),
        new DocumentModuleType('solution'),
        new DocumentModuleType('theorem'),
        new DocumentModuleType('proof'),
        new DocumentModuleType('reminder'),
        new DocumentModuleType('proposition'),
    ];

    /**
    * A module is a numbered element of content with a localized header.
    */
    class DocumentModule {
        /**
        * Constructs a well-defined module.
        * @param {String} title the optional title of the module.
        * @param {String} type the name of the module's type.
        * @param {Number|String} number the number of the module. If it is
        * unspecified, then the count of modules of the given type is
        * incremented, and the module's number corresponds to the count of
        * modules of the same type.
        * @param {Boolean} expanded whether or not the module is initially
        * expanded.
        */
        constructor(title, type, number, expanded = true) {
            this.title = title;
            if (!type) {
                throw new Error('Undefined module type for the module.');
            }
            this.type = DocumentModuleType.of(type);
            this.expanded = expanded;
            if (number) {
                this.number = number;
            } else {
                this.number = ++this.type.count;
            }
        }

        /**
        * @returns {String} the localized name of this module's type.
        */
        get localizedTypeName() {
            return DocumentModule.VARIABLES[this.type.name];
        }
    }

    /**
    * The localized variables concerning redaction modules.
    */
    DocumentModule.VARIABLES = LOCALE.variables.redaction.modules;

//- Adds a module to the document.
    @param {DocumentModule} documentModule the module to add.
mixin module(documentModule)
    section.module(class!=documentModule.type.name
        id!=documentModule.type.name + '-' + documentModule.number)
        header
            -
                let moduleLevel = currentSectionLevel >= 6 ? 
                    6 : currentSectionLevel + 1;
            -
                let moduleTitle = documentModule.localizedTypeName;
                moduleTitle += ' ' + documentModule.number;
                if (documentModule.title) {
                    moduleTitle += ': ' + documentModule.title;
                }
            +moduleHeadline(moduleLevel, moduleTitle)
            if attributes.header
                if attributes.header.difficulty
                    +difficulty(attributes.header.difficulty)
            i.fa.fa-fw.toggler(
                class!=documentModule.expanded ? 
                    'fa-caret-up' : 'fa-caret-down')
        .content(aria-expanded=documentModule.expanded.toString())
            block
        if attributes.footer
            footer
                if attributes.footer.reminder
                    +extLink(attributes.footer.reminder)
                        =DocumentModule.VARIABLES.reminderLinkBack
                if attributes.footer.source
                    +extLink(attributes.footer.source)
                        =DocumentModule.VARIABLES.source

//- Adds a module headline.
    @param {Number} the level of the headline.
    @param {String} headline the headline to add.
mixin moduleHeadline(level, headline)
    case level
        when 2: h2=headline
        when 3: h3=headline
        when 4: h4=headline
        when 5: h5=headline
        when 6: h6=headline
        default
            -
                throw new Error(
                    'Invalid level ' + level + ' for headline ' + headline
                );

//- Adds a numbered definition block.
    @param {String} title the title of the definition.
    Usage:
    +definition('Functions')
        p A function is ...
mixin definition(title)
    +module(new DocumentModule(title, 'definition'))&attributes(attributes)
        block
           
//- Adds a numbered example block.
    @param {String} title the title of the example.
    Usage:
    +example()
        p Given the values of ...        
mixin example(title)
    +module(new DocumentModule(title, 'example'))&attributes(attributes)
        block

-let proofNumber = 0;

//- Adds a numbered theorem block.
    @param {String} title the title of the theorem.
    Usage:
    +theorem()
        p Given the values of ...
mixin theorem(title)
    -proofNumber = 0;
    +module(new DocumentModule(title, 'theorem'))&attributes(attributes)
        block

//- Adds a numbered proof block. Proofs are collapsed by default.
    Should only be featured in a theorem block.
    @param {String} title the title of the proof.
    Usage:
    +theorem()
        p ...
        +proof()
            p ... 
mixin proof(title)
    -proofNumber++;
    +module(
        new DocumentModule(title, 'proof', proofNumber, false)
    )&attributes(attributes)
        block

-let solutionNumber = 0;

//- Adds a numbered exercise block.
    @param {Number} difficulty the difficulty of the exercise on a scale from 
    0 to 5 with 0.5 steps.
    @param {String} title the title of the exercise.
    Usage:
    +exercise()
        p Solve the following ...
mixin exercise(difficulty, title)
    -solutionNumber = 0;
    if difficulty
        -Object.assign(attributes, {header: {difficulty: difficulty}});
    +module(new DocumentModule(title, 'exercise'))&attributes(attributes)
        block

//- Adds a numbered solution block. Solutions are collapsed by default.
    Should only be featured in an exercise block.
    @param {String} title the title of the solution.
    Usage:
    +exercise()
        p ...
        +solution()
            p ...
mixin solution(title)
    -solutionNumber++;
    +module(
        new DocumentModule(title, 'solution', solutionNumber, false)
    )&attributes(attributes)
        block

//- Adds a numbered reminder block.
    @param {String} title the title of the reminder.
    @param {String} linkback the link back to the article that explains the
    content of the reminder.
mixin reminder(title, linkback)
    if linkback
        -Object.assign(attributes, {footer: {reminder: linkback}});
    +module(new DocumentModule(title, 'reminder'))&attributes(attributes)
        block