//- MathJax reference: https://math.meta.stackexchange.com/questions/5020/mathjax-basic-tutorial-and-quick-reference

-
    /**
    * LaTeX inline math delimiters.
    */
    const inlineMathDelimiters = {
        prefix: '\\(',
        suffix: '\\)',
    };

    /**
    * LaTeX displayed math delimiters.
    */
    const displayedMathDelimiters = {
        prefix: '$$',
        suffix: '$$',
    };

//- Delimits an inline MathJax expression.
    Usage:
    p The difference of square ... #[+e() x^2-1=(x-1)(x+1)]
mixin e()
    != inlineMathDelimiters.prefix
    block
    != inlineMathDelimiters.suffix

//- Delimits a displayed MathJax expression.
    Should not be used as an inline mixin.
    Usage:
    +eq().
        (x+2)^3&=(x+2)(x+2)(x+2)
        \\&=(x^2+2x+2x+4)(x+2)
        \\&=(x^2+4x+4)(x+2)&&\text{Combine like terms}
        \\&=(x^3+4x^2+4x+2x^2+8x+8)
        \\&=x^3+6x^2+12x+8
mixin eq()
    != displayedMathDelimiters.prefix
    != '\\begin{align*}'
    block
    != '\\end{align*}'
    != displayedMathDelimiters.suffix

//- Delimits a labeled displayed MathJax equation.
    Should not be used as an inline mixin.
    @param {String} label the identification label of the numbered equation.
    Usage:
    +leq('quadratic') x=\frac{-b\pm\sqrt{b^2-4ac}}{2a}
mixin leq(label)
    != displayedMathDelimiters.prefix
    != '\\begin{equation}'
    block
    = '\\label{' + label + '}'
    != '\\end{equation}'
    != displayedMathDelimiters.suffix

//- Delimits a MathJax equation reference.
    @param {String} label the identification label of the referenced equation.
    Usage:
    p The quadratic formula #[+eqref('quadratic')] [...]
mixin eqref(label)
    !=inlineMathDelimiters.prefix
    !='\\eqref{'
    =label
    !='}'
    block
    !=inlineMathDelimiters.suffix