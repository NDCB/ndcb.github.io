-
    class Website {

        /**
         * @returns {String} the name of this website.
         */
        get name() {
            return this._name;
        }

        /**
         * @returns {String} the URL of this website.
         */
        get url() {
            return this._url;
        }

        /**
         * @returns {String} the sourc URL of this website.
         */
        get sourceUrl() {
            return this._sourceUrl;
        }

        /**
         * @returns {Object} the authentification codes of this website as 
         * attributes.
         */
        get authentifications() {
            return this._authentifications;
        }

    }

